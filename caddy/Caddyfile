# TLS for aivaerp.com and every *.aivaerp.com tenant subdomain, using the
# existing certbot wildcard certificate (Domains: aivaerp.com *.aivaerp.com,
# valid until 2026-09-09). Because the cert covers the wildcard, any new
# tenant subdomain gets HTTPS automatically -- no per-domain config needed.
#
# Renewing this cert requires a manual DNS-01 challenge (authenticator =
# manual in /etc/letsencrypt/renewal/aivaerp.com.conf, no auto-renew hook).
# After renewing, reload this container so Caddy picks up the new files:
#   docker compose -f docker-compose.caddy.yml restart caddy
aivaerp.com, *.aivaerp.com {
	tls /etc/letsencrypt/live/aivaerp.com/fullchain.pem /etc/letsencrypt/live/aivaerp.com/privkey.pem
	reverse_proxy frontend:8080
}
