{
	email ops@aivaerp.com

	# Issue a real Let's Encrypt cert on first request for any hostname
	# that passes the check below — no wildcard cert, no DNS provider
	# credentials needed. Works for any subdomain (current or future
	# tenant) whose DNS already points at this server.
	on_demand_tls {
		ask http://localhost:2021/check-domain
		interval 2m
		burst 5
	}
}

# Internal-only: validates a hostname before Caddy requests a cert for it.
# If the base domain ever changes (or more domains are added), update the
# `query domain=...` patterns below.
:2021 {
	@root_domain {
		query domain=aivaerp.com
	}
	@sub_domain {
		query domain=*.aivaerp.com
	}
	handle @root_domain {
		respond "" 200
	}
	handle @sub_domain {
		respond "" 200
	}
	respond "" 403
}

# Matches aivaerp.com and any current/future subdomain (tenants).
aivaerp.com, *.aivaerp.com {
	tls {
		on_demand
	}
	reverse_proxy frontend:8080
}
